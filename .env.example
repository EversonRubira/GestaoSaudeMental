# Configurações da API de IA
# Para habilitar respostas com IA, copie este arquivo para .env e preencha as variáveis

# Habilitar/Desabilitar IA (true/false)
AI_ENABLED=false

# Chave da API da OpenAI
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sua-chave-aqui

# Modelo da OpenAI (opcional)
# Opções: gpt-3.5-turbo, gpt-4, gpt-4-turbo, etc.
OPENAI_API_MODEL=gpt-3.5-turbo
